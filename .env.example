# ----------------------------------------------------------------------------
# .env.example — PRANAV environment template
#
# NEVER COMMIT .env. This file (.env.example) is the only env-shaped file that
# belongs in git. Copy it to `.env` for local development:
#
#     cp .env.example .env
#
# The repo's .gitignore excludes `.env` and `.env.*` (with a `.env.example`
# allow-list exception); a fresh `.env` will not show up in `git status`.
#
# DATABASE_URL is intentionally NOT listed as a separate top-level entry.
# docker-compose.yml interpolates it from the POSTGRES_* variables below so
# self-hosters only manage one source of truth for credentials. For native
# (non-Docker) development against a local Postgres, uncomment the line at
# the bottom of this file.
# ----------------------------------------------------------------------------

# Postgres (consumed by docker-compose to build the postgres container AND
# composed into DATABASE_URL for the api container).
POSTGRES_USER=pranav
POSTGRES_PASSWORD=pranav_dev_password
POSTGRES_DB=pranav

# API runtime
SECRET_KEY=change-me-in-prod-use-openssl-rand-hex-32
ENVIRONMENT=dev
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# Web runtime
NEXT_PUBLIC_API_URL=http://localhost:8000

# Native-dev only (uncomment if you run the api outside Docker against a
# local Postgres). docker-compose builds this URL itself; do not override.
# DATABASE_URL=postgresql+asyncpg://pranav:pranav_dev_password@localhost:5432/pranav
